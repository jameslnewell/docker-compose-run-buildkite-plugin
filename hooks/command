#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${DIR}/../lib/shared.bash"

SERVICE="${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_SERVICE}"
PROJECT="docker-compose-run-buildkite-plugin-${BUILDKITE_JOB_ID}"

mapfile -t FILES < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_FILE")
FILE_ARGS=()
for f in "${FILES[@]}"; do
  FILE_ARGS+=(-f "$f")
done

echo "--- :docker: pulling"
# TODO: pass "$SERVICE --include-deps" once the flag is broadly available, so we only pull what's needed
set -x
docker compose -p "$PROJECT" "${FILE_ARGS[@]}" pull
{ set +x; } 2>/dev/null

echo "--- :docker: upping"
# Enumerate deps explicitly rather than --scale SERVICE=0: some compose versions
# wait indefinitely for a scaled-to-zero service that never becomes healthy.
mapfile -t DEP_SERVICES < <(docker compose -p "$PROJECT" "${FILE_ARGS[@]}" config --services | grep -v "^${SERVICE}$")
if [[ ${#DEP_SERVICES[@]} -gt 0 ]]; then
  set -x
  docker compose -p "$PROJECT" "${FILE_ARGS[@]}" up --wait "${DEP_SERVICES[@]}"
  { set +x; } 2>/dev/null
fi

echo "+++ :docker: running"

# --no-build and --pull were added to `docker compose run` in later Compose versions; skip on older
COMPOSE_RUN_HELP="$(docker compose run --help 2>&1)"
RUN_NO_BUILD_ARGS=()
if echo "$COMPOSE_RUN_HELP" | grep -q -- '--no-build'; then
  RUN_NO_BUILD_ARGS+=(--no-build)
fi
RUN_PULL_ARGS=()
if echo "$COMPOSE_RUN_HELP" | grep -q -- '--pull'; then
  RUN_PULL_ARGS+=(--pull never)
fi

RUN_ARGS=()
workdir="${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_WORKDIR:-}"
[[ -n "$workdir" ]] && RUN_ARGS+=(--workdir "$workdir")

entrypoint=""
if [[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_ENTRYPOINT+set}" == "set" ]]; then
  entrypoint="${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_ENTRYPOINT}"
  RUN_ARGS+=(--entrypoint "$entrypoint")
fi

mapfile -t ENVS < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_ENVIRONMENT")
for e in "${ENVS[@]}"; do
  RUN_ARGS+=(-e "$e")
done

if [[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_PROPAGATE_AWS:-false}" == "true" ]]; then
  RUN_ARGS+=(-e "AWS_REGION")
  RUN_ARGS+=(-e "AWS_DEFAULT_REGION")
  RUN_ARGS+=(-e "AWS_ACCESS_KEY_ID")
  RUN_ARGS+=(-e "AWS_SECRET_ACCESS_KEY")
  RUN_ARGS+=(-e "AWS_SESSION_TOKEN")
fi

if [[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_PROPAGATE_BUILDKITE_ENVIRONMENT:-false}" == "true" ]]; then
  while IFS='=' read -r key _; do
    if [[ "$key" == "CI" || "$key" == "BUILDKITE" || "$key" == BUILDKITE_* ]]; then
      RUN_ARGS+=(-e "$key")
    fi
  done < <(env)
fi

mapfile -t VOLUMES < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_VOLUMES")
for v in "${VOLUMES[@]}"; do
  if [[ "$v" == *:* ]]; then
    host="${v%%:*}"
    rest="${v#*:}"
    if [[ "$host" == .* ]]; then
      host="$(pwd)${host#.}"
    fi
    v="${host}:${rest}"
  fi
  RUN_ARGS+=(-v "$v")
done

if [[ -n "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_COMMAND:-}" && -z "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_COMMAND_0:-}" ]]; then
  echo "+++ Error: The command option must be an array, not a string. Use command: ['arg1', 'arg2']."
  exit 1
fi
mapfile -t CMD_ITEMS < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_COMMAND")
has_step_commands=false
[[ -n "${BUILDKITE_COMMAND:-}" ]] && has_step_commands=true
has_plugin_commands=false
[[ ${#CMD_ITEMS[@]} -gt 0 ]] && has_plugin_commands=true

if [[ "$has_step_commands" == "true" && "$has_plugin_commands" == "true" ]]; then
  echo "+++ Error: Cannot specify both step commands and plugin commands. Move commands to the step or to the plugin 'command' option, not both."
  exit 1
fi

# Determine shell (only applies to step commands)
SHELL_ARGS=()
shell_enabled=true
shell_explicitly_set=false
if [[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_SHELL:-}" =~ ^(false|off|0)$ ]]; then
  shell_enabled=false
elif [[ -n "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_SHELL_0:-}" ]]; then
  mapfile -t SHELL_ARGS < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_SHELL")
  shell_explicitly_set=true
elif [[ -n "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_SHELL:-}" ]]; then
  echo "+++ Error: The shell option must be an array or false, not a string."
  exit 1
else
  SHELL_ARGS=("/bin/sh" "-e" "-c")
fi

# Any entrypoint (even "") suppresses shell wrapping — matches official buildkite docker plugin.
[[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_ENTRYPOINT+set}" == "set" ]] && shell_enabled=false

# Error if shell was explicitly set as an array but entrypoint suppresses it.
if [[ "${BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_ENTRYPOINT+set}" == "set" && "$shell_explicitly_set" == "true" ]]; then
  echo "+++ Error: The shell option has no effect when entrypoint is set — entrypoint suppresses shell wrapping."
  exit 1
fi

CMD_ARGS=()
if [[ "$has_step_commands" == "true" ]]; then
  if [[ "$shell_enabled" == "true" ]]; then
    CMD_ARGS+=("${SHELL_ARGS[@]}" "$BUILDKITE_COMMAND")
  else
    CMD_ARGS+=("$BUILDKITE_COMMAND")
  fi
elif [[ "$has_plugin_commands" == "true" ]]; then
  # Plugin commands are passed directly as container CMD args — no shell wrapper
  CMD_ARGS+=("${CMD_ITEMS[@]}")
fi

set -x
docker compose -p "$PROJECT" "${FILE_ARGS[@]}" run \
  --no-deps \
  "${RUN_NO_BUILD_ARGS[@]}" \
  "${RUN_PULL_ARGS[@]}" \
  --rm \
  "${RUN_ARGS[@]}" \
  "$SERVICE" \
  "${CMD_ARGS[@]}"
{ set +x; } 2>/dev/null
