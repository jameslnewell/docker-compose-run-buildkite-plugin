#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${DIR}/../lib/shared.bash"

PROJECT="docker-compose-run-buildkite-plugin-${BUILDKITE_JOB_ID}"

mapfile -t FILES < <(plugin_read_list "BUILDKITE_PLUGIN_DOCKER_COMPOSE_RUN_FILE")
FILE_ARGS=()
for f in "${FILES[@]}"; do
  FILE_ARGS+=(-f "$f")
done

echo "--- :docker: logging"
set -x
docker compose -p "$PROJECT" "${FILE_ARGS[@]}" logs --timestamps 2>&1 \
  | sort > docker-compose-run-plugin.log || true
{ set +x; } 2>/dev/null
buildkite-agent artifact upload docker-compose-run-plugin.log || true

echo "--- :docker: downing"
set -x
docker compose -p "$PROJECT" "${FILE_ARGS[@]}" down --volumes --remove-orphans || true
{ set +x; } 2>/dev/null
